---
// apps/landing-page/src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard';
import { getLocalBlogPosts } from '../../utils/blog';

const allPosts = await getLocalBlogPosts();

const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<Layout
  title="Blog | RefearnApp - SaaS Affiliate Strategy"
  description="Guides, updates, and expert insights on building high-growth affiliate programs."
>
  <Header />

  <main class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <!-- Header code omitted for brevity -->

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3">
      {
        allPosts.map((post) => {
          const extension = post.data.imageExt || 'png';
          const computedHero = `/blog-assets/${post.data.image}/hero.${extension}`;

          return (
            <BlogCard
              client:load
              title={post.data.title}
              date={formatDate(post.data.date)}
              slug={post.id}
              image={computedHero}
            />
          );
        })
      }
    </div>
  </main>

  <Footer />
</Layout>